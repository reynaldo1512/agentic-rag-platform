# ==============================================================================
# Agentic RAG Platform — Backend Environment Variables
# ==============================================================================
# Copia este archivo como ".env" y completa los valores según tu entorno.
#
# IMPORTANTE: en esta iteración (bootstrap) estas variables solo se DECLARAN
# y se cargan mediante la configuración de la aplicación. Ninguna de ellas
# es consumida todavía por lógica de negocio real.
# ==============================================================================

# --- Proveedores externos (uso futuro: Agentic RAG) -------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here
TAVILY_API_KEY=tvly-your-tavily-api-key-here

# --- Modelo LLM (uso futuro: nodos del grafo) --------------------------------
MODEL_NAME=gpt-4o-mini

# --- Aplicación ---------------------------------------------------------------
LOG_LEVEL=INFO
API_PORT=8000
